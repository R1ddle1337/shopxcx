<view class="admin-page">
  <view class="toolbar">
    <view>
      <view class="toolbar__title">分类管理</view>
      <view class="toolbar__desc">管理首页和分类页使用的顶层分类结构。</view>
    </view>
    <t-button theme="primary" size="small" bind:tap="handleCreate">新增分类</t-button>
  </view>

  <view wx:if="{{loading}}" class="loading-wrap">
    <t-loading theme="circular" text="加载分类中..." />
  </view>

  <block wx:elif="{{categoryList.length}}">
    <view class="category-card" wx:for="{{categoryList}}" wx:key="groupId">
      <image class="category-card__thumb" src="{{item.thumbnail}}" mode="aspectFill" />

      <view class="category-card__content">
        <view class="category-card__title">{{item.name}}</view>
        <view class="category-card__meta">ID：{{item.groupId}}</view>
        <view class="category-card__meta">专题：{{item.sectionName || '-'}}</view>
        <view class="category-card__meta">示例：{{item.sampleItemName || '-'}}</view>
        <view class="category-card__meta">关联商品：{{item.goodsCountText}}</view>

        <view class="category-card__actions">
          <t-button variant="outline" size="small" data-group-id="{{item.groupId}}" bind:tap="handleEdit">编辑</t-button>
          <t-button
            theme="danger"
            variant="outline"
            size="small"
            data-group-id="{{item.groupId}}"
            data-name="{{item.name}}"
            bind:tap="handleDelete"
          >
            删除
          </t-button>
        </view>
      </view>
    </view>
  </block>

  <view wx:else class="empty-state">
    <view class="empty-state__title">还没有分类</view>
    <view class="empty-state__desc">新增一个分类后，分类页就能显示新的入口。</view>
  </view>

  <t-toast id="t-toast" />
</view>
