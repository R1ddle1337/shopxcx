page {
  background: #f6f8f2;
}

.admin-page {
  padding: 28rpx;
}

.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.toolbar__title {
  font-size: 40rpx;
  font-weight: 600;
  color: #233119;
}

.toolbar__desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #6a7562;
}

.loading-wrap,
.empty-state {
  margin-top: 80rpx;
  text-align: center;
  color: #6a7562;
}

.empty-state__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #233119;
}

.empty-state__desc {
  margin-top: 12rpx;
  font-size: 24rpx;
}

.category-card {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(44, 74, 29, 0.08);
}

.category-card__thumb {
  flex-shrink: 0;
  width: 148rpx;
  height: 148rpx;
  border-radius: 20rpx;
  background: #eef4e6;
}

.category-card__content {
  flex: 1;
  min-width: 0;
}

.category-card__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #233119;
}

.category-card__meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6a7562;
}

.category-card__actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}
