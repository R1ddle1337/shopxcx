page {
  background: #f6f8f2;
}

.admin-page {
  padding: 28rpx;
}

.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.toolbar__title {
  font-size: 40rpx;
  font-weight: 600;
  color: #233119;
}

.toolbar__desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #6a7562;
}

.toolbar__count {
  flex-shrink: 0;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #ecf8e5;
  color: #3d8d29;
  font-size: 22rpx;
}

.filter-card,
.order-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(44, 74, 29, 0.08);
}

.filter-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.filter-card__label {
  font-size: 24rpx;
  color: #6a7562;
}

.picker-field {
  min-width: 180rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f2f6ec;
  font-size: 24rpx;
  color: #233119;
}

.loading-wrap,
.empty-state {
  margin-top: 80rpx;
  text-align: center;
  color: #6a7562;
}

.empty-state__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #233119;
}

.empty-state__desc {
  margin-top: 12rpx;
  font-size: 24rpx;
}

.order-card {
  margin-bottom: 18rpx;
}

.order-card__header {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.order-card__no {
  font-size: 28rpx;
  font-weight: 600;
  color: #233119;
}

.order-card__status {
  color: #3d8d29;
  font-size: 24rpx;
}

.order-card__meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6a7562;
}

.order-card__amount {
  margin-top: 16rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #d54524;
}
