<view class="editor-page">
  <view wx:if="{{loading}}" class="loading-wrap">
    <t-loading theme="circular" text="加载订单详情中..." />
  </view>

  <block wx:elif="{{order}}">
    <view class="section__title">订单信息</view>
    <view class="panel info-panel">
      <view class="info-row">
        <view class="info-row__label">订单号</view>
        <view class="info-row__value">{{order.orderNo}}</view>
      </view>
      <view class="info-row">
        <view class="info-row__label">收货人</view>
        <view class="info-row__value">{{order.logisticsVO.receiverName}} {{order.logisticsVO.receiverPhone}}</view>
      </view>
      <view class="info-row">
        <view class="info-row__label">地址</view>
        <view class="info-row__value address">{{order.logisticsVO.receiverCity}}{{order.logisticsVO.receiverCountry}}{{order.logisticsVO.receiverArea}}{{order.logisticsVO.receiverAddress}}</view>
      </view>
      <view class="info-row">
        <view class="info-row__label">商品金额</view>
        <view class="info-row__value">￥{{order.goodsAmountText}}</view>
      </view>
      <view class="info-row">
        <view class="info-row__label">应付金额</view>
        <view class="info-row__value accent">￥{{order.paymentAmountText}}</view>
      </view>
    </view>

    <view class="section__title">商品清单</view>
    <view class="goods-card" wx:for="{{order.orderItemVOs}}" wx:key="id">
      <image class="goods-card__thumb" src="{{item.goodsPictureUrl}}" mode="aspectFill" />
      <view class="goods-card__content">
        <view class="goods-card__title">{{item.goodsName}}</view>
        <view class="goods-card__meta">{{item.specText || '-'}}</view>
        <view class="goods-card__meta">x{{item.buyQuantity}}</view>
      </view>
    </view>

    <view class="section__title">管理操作</view>
    <view class="panel">
      <view class="field">
        <view class="field__label">订单状态</view>
        <picker range="{{statusOptions}}" range-key="label" value="{{statusIndex}}" bindchange="onStatusChange">
          <view class="picker-field">{{statusOptions[statusIndex].label}}</view>
        </picker>
      </view>

      <view class="field">
        <view class="field__label">物流单号</view>
        <t-input
          value="{{form.logisticsNo}}"
          placeholder="如：YT123456789"
          borderless
          data-field="logisticsNo"
          bind:change="onFieldChange"
        />
      </view>

      <view class="field">
        <view class="field__label">物流公司</view>
        <t-input
          value="{{form.logisticsCompanyName}}"
          placeholder="如：圆通速递"
          borderless
          data-field="logisticsCompanyName"
          bind:change="onFieldChange"
        />
      </view>

      <view class="field">
        <view class="field__label">物流电话</view>
        <t-input
          value="{{form.logisticsCompanyTel}}"
          placeholder="如：95554"
          borderless
          data-field="logisticsCompanyTel"
          bind:change="onFieldChange"
        />
      </view>

      <view class="field">
        <view class="field__label">订单备注</view>
        <t-textarea
          value="{{form.remark}}"
          placeholder="给仓配或客服的内部备注"
          autosize
          data-field="remark"
          bind:change="onFieldChange"
        />
      </view>
    </view>

    <view class="submit-bar">
      <t-button theme="primary" size="large" block loading="{{saving}}" bind:tap="handleSave">保存订单</t-button>
    </view>
  </block>

  <t-toast id="t-toast" />
</view>
