page {
  background: #f6f8f2;
}

.admin-page {
  padding: 28rpx;
}

.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.toolbar__title {
  font-size: 40rpx;
  font-weight: 600;
  color: #233119;
}

.toolbar__desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #6a7562;
}

.loading-wrap,
.empty-state {
  margin-top: 80rpx;
  text-align: center;
  color: #6a7562;
}

.empty-state__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #233119;
}

.empty-state__desc {
  margin-top: 12rpx;
  font-size: 24rpx;
}

.goods-card {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(44, 74, 29, 0.08);
}

.goods-card__thumb {
  flex-shrink: 0;
  width: 180rpx;
  height: 180rpx;
  border-radius: 20rpx;
  background: #eef4e6;
}

.goods-card__content {
  flex: 1;
  min-width: 0;
}

.goods-card__header {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.goods-card__title {
  flex: 1;
  font-size: 30rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #233119;
}

.goods-card__status {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.goods-card__status.up {
  background: #ecf8e5;
  color: #3d8d29;
}

.goods-card__status.down {
  background: #f5f5f5;
  color: #777;
}

.goods-card__meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6a7562;
}

.goods-card__tag {
  display: inline-block;
  margin-top: 12rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #fff3df;
  color: #b87412;
  font-size: 22rpx;
}

.goods-card__price-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-top: 20rpx;
}

.goods-card__price {
  font-size: 34rpx;
  font-weight: 700;
  color: #d54524;
}

.goods-card__line-price {
  font-size: 24rpx;
  color: #9aa290;
  text-decoration: line-through;
}

.goods-card__actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}
