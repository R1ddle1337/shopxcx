<view class="admin-page">
  <view class="toolbar">
    <view>
      <view class="toolbar__title">商品管理</view>
      <view class="toolbar__desc">新增、编辑、删除都会直接写入本地商品数据。</view>
    </view>
    <t-button theme="primary" size="small" bind:tap="handleCreate">新增商品</t-button>
  </view>

  <view wx:if="{{loading}}" class="loading-wrap">
    <t-loading theme="circular" text="加载商品中..." />
  </view>

  <block wx:elif="{{goodsList.length}}">
    <view class="goods-card" wx:for="{{goodsList}}" wx:key="spuId">
      <image class="goods-card__thumb" src="{{item.primaryImage}}" mode="aspectFill" />

      <view class="goods-card__content">
        <view class="goods-card__header">
          <view class="goods-card__title">{{item.title}}</view>
          <view class="goods-card__status {{item.isPutOnSale === 1 ? 'up' : 'down'}}">
            {{item.isPutOnSale === 1 ? '上架中' : '已下架'}}
          </view>
        </view>

        <view class="goods-card__meta">{{item.categoryName}} · {{item.skuCountText}} 个规格 · 库存 {{item.stockText}}</view>
        <view wx:if="{{item.tagTitle}}" class="goods-card__tag">{{item.tagTitle}}</view>

        <view class="goods-card__price-row">
          <view class="goods-card__price">￥{{item.minSalePriceText}}</view>
          <view class="goods-card__line-price">￥{{item.maxLinePriceText}}</view>
        </view>

        <view class="goods-card__actions">
          <t-button variant="outline" size="small" data-spu-id="{{item.spuId}}" bind:tap="handleEdit">编辑</t-button>
          <t-button
            theme="danger"
            variant="outline"
            size="small"
            data-spu-id="{{item.spuId}}"
            data-title="{{item.title}}"
            bind:tap="handleDelete"
          >
            删除
          </t-button>
        </view>
      </view>
    </view>
  </block>

  <view wx:else class="empty-state">
    <view class="empty-state__title">还没有商品</view>
    <view class="empty-state__desc">先新增一个果蔬商品，首页和分类页就能读到。</view>
  </view>

  <t-toast id="t-toast" />
</view>
