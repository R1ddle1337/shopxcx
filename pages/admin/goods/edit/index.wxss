page {
  background: #f6f8f2;
}

.editor-page {
  padding: 24rpx 24rpx 48rpx;
}

.loading-wrap {
  margin-top: 120rpx;
  text-align: center;
}

.section,
.preview-card {
  margin-bottom: 24rpx;
}

.section__title {
  margin-bottom: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #233119;
}

.section__desc {
  margin-bottom: 16rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6a7562;
}

.panel,
.sku-card,
.preview-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(44, 74, 29, 0.08);
}

.field {
  padding: 22rpx 0;
}

.field + .field {
  border-top: 1px solid #edf1e7;
}

.field__label {
  margin-bottom: 10rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #233119;
}

.field__hint {
  font-size: 22rpx;
  line-height: 1.5;
  color: #7a8571;
}

.field--switch {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
}

.picker-field {
  min-height: 64rpx;
  display: flex;
  align-items: center;
  padding: 0 8rpx;
  font-size: 28rpx;
  color: #233119;
}

.preview-card__image {
  width: 100%;
  height: 320rpx;
  margin-top: 8rpx;
  border-radius: 20rpx;
  background: #eef4e6;
}

.sku-card {
  margin-bottom: 16rpx;
}

.sku-card__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.sku-card__title {
  font-size: 28rpx;
  font-weight: 600;
  color: #233119;
}

.field-row {
  display: flex;
  gap: 20rpx;
}

.field-row__item {
  flex: 1;
}

.submit-bar {
  margin-top: 32rpx;
  padding-bottom: env(safe-area-inset-bottom);
}
