<view class="editor-page">
  <view wx:if="{{loading}}" class="loading-wrap">
    <t-loading theme="circular" text="加载商品配置中..." />
  </view>

  <block wx:else>
    <view class="section">
      <view class="section__title">基础信息</view>
      <view class="panel">
        <view class="field">
          <view class="field__label">商品名称</view>
          <t-input value="{{form.title}}" placeholder="如：云南高山蓝莓" borderless data-field="title" bind:change="onFieldChange" />
        </view>

        <view class="field">
          <view class="field__label">所属分类</view>
          <picker range="{{categoryOptions}}" range-key="label" value="{{categoryIndex}}" bindchange="onCategoryChange">
            <view class="picker-field">{{categoryLabel}}</view>
          </picker>
        </view>

        <view class="field">
          <view class="field__label">主图路径</view>
          <t-input
            value="{{form.primaryImage}}"
            placeholder="/assets/produce/apple.svg"
            borderless
            data-field="primaryImage"
            bind:change="onFieldChange"
          />
        </view>

        <view class="field">
          <view class="field__label">标签文案</view>
          <t-input value="{{form.tagTitle}}" placeholder="如：当季直发" borderless data-field="tagTitle" bind:change="onFieldChange" />
        </view>

        <view class="field">
          <view class="field__label">限购说明</view>
          <t-input value="{{form.limitText}}" placeholder="如：限购 3 件" borderless data-field="limitText" bind:change="onFieldChange" />
        </view>

        <view class="field">
          <view class="field__label">已售数量</view>
          <t-input value="{{form.soldNum}}" type="number" placeholder="0" borderless data-field="soldNum" bind:change="onFieldChange" />
        </view>

        <view class="field field--switch">
          <view>
            <view class="field__label">上架状态</view>
            <view class="field__hint">关闭后商品会保留在后台，但前台按下架处理。</view>
          </view>
          <t-switch value="{{form.isPutOnSale}}" bind:change="onShelfChange" />
        </view>
      </view>
    </view>

    <view wx:if="{{form.primaryImage}}" class="preview-card">
      <view class="section__title">主图预览</view>
      <image class="preview-card__image" src="{{form.primaryImage}}" mode="aspectFill" />
    </view>

    <view class="section">
      <view class="section__title">规格与价格</view>
      <view class="section__desc">一个规格对应一个 SKU，适合果蔬店常见的 500g、2kg、礼盒装等场景。</view>

      <view class="sku-card" wx:for="{{form.skuItems}}" wx:key="index">
        <view class="sku-card__header">
          <view class="sku-card__title">规格 {{index + 1}}</view>
          <t-button theme="danger" variant="text" size="small" data-index="{{index}}" bind:tap="removeSku">删除</t-button>
        </view>

        <view class="field">
          <view class="field__label">规格名称</view>
          <t-input
            value="{{item.specValue}}"
            placeholder="如：家庭装 2kg"
            borderless
            data-index="{{index}}"
            data-field="specValue"
            bind:change="onSkuFieldChange"
          />
        </view>

        <view class="field-row">
          <view class="field field-row__item">
            <view class="field__label">售价（元）</view>
            <t-input
              value="{{item.salePrice}}"
              type="digit"
              placeholder="0.00"
              borderless
              data-index="{{index}}"
              data-field="salePrice"
              bind:change="onSkuFieldChange"
            />
          </view>

          <view class="field field-row__item">
            <view class="field__label">划线价（元）</view>
            <t-input
              value="{{item.linePrice}}"
              type="digit"
              placeholder="0.00"
              borderless
              data-index="{{index}}"
              data-field="linePrice"
              bind:change="onSkuFieldChange"
            />
          </view>
        </view>

        <view class="field-row">
          <view class="field field-row__item">
            <view class="field__label">库存</view>
            <t-input
              value="{{item.stockQuantity}}"
              type="number"
              placeholder="0"
              borderless
              data-index="{{index}}"
              data-field="stockQuantity"
              bind:change="onSkuFieldChange"
            />
          </view>

          <view class="field field-row__item">
            <view class="field__label">重量（kg）</view>
            <t-input
              value="{{item.weight}}"
              type="digit"
              placeholder="1"
              borderless
              data-index="{{index}}"
              data-field="weight"
              bind:change="onSkuFieldChange"
            />
          </view>
        </view>

        <view class="field">
          <view class="field__label">SKU 图片</view>
          <t-input
            value="{{item.skuImage}}"
            placeholder="默认跟随主图"
            borderless
            data-index="{{index}}"
            data-field="skuImage"
            bind:change="onSkuFieldChange"
          />
        </view>
      </view>

      <t-button variant="outline" bind:tap="addSku">新增规格</t-button>
    </view>

    <view class="section">
      <view class="section__title">详情图片</view>
      <view class="section__desc">每行一张图片路径。轮播图为空时会默认只展示主图。</view>

      <view class="panel">
        <view class="field">
          <view class="field__label">轮播图</view>
          <t-textarea
            value="{{form.carouselImagesText}}"
            placeholder="/assets/produce/apple.svg"
            autosize
            data-field="carouselImagesText"
            bind:change="onFieldChange"
          />
        </view>

        <view class="field">
          <view class="field__label">详情图</view>
          <t-textarea
            value="{{form.detailImagesText}}"
            placeholder="/assets/produce/detail-farm.svg"
            autosize
            data-field="detailImagesText"
            bind:change="onFieldChange"
          />
        </view>
      </view>
    </view>

    <view class="submit-bar">
      <t-button theme="primary" size="large" block loading="{{saving}}" bind:tap="handleSubmit">
        {{isEdit ? '保存商品' : '创建商品'}}
      </t-button>
    </view>
  </block>

  <t-toast id="t-toast" />
</view>
